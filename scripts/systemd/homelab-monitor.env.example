# Copy to /etc/homelab-monitor.env (root-owned, chmod 600) and fill in.
# All values are optional; with none set, the checker just writes a report
# to /var/lib/homelab-monitor/last-report.txt and notifies nothing.

# --- Push notifications (pick zero, one, or both) ---
# ntfy.sh topic (self-host or public). You get a push on phone/desktop.
#NTFY_URL="https://ntfy.sh/t430-homelab-7f3k"

# Discord / Slack-style incoming webhook (posts JSON {content|text}).
#WEBHOOK_URL="https://discord.com/api/webhooks/XXXX/YYYY"

# --- GitHub Actions monitoring ---
#GITHUB_REPO="isaacmadearis/t430-homelab"
# Optional fine-grained/classic PAT (repo:read). Lifts the 60/hr unauth API
# rate limit and is REQUIRED if the repo is private. Leave unset for public.
#GITHUB_TOKEN="ghp_xxx"

# --- Overrides (usually leave default) ---
#REPO_DIR="/home/imadear/t430-homelab"
#STATE_DIR="/var/lib/homelab-monitor"
#OLLAMA_PIN="0.23.2"   # force the version compared against GitHub latest
